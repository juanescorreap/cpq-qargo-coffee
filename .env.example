# Copy to .env (local) or set these in the deploy platform (Railway).
# NEVER commit the real .env.

# ── Database (Supabase) ─────────────────────────────────────────────
# Direct connection (legacy name DATABASE_URL also accepted)
SUPABASE_DB_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Pooler (legacy name DATABASE_URL_POOLING also accepted) — used by the app
SUPABASE_POOLER_URL=postgresql://USER:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
# Optional read replica for context prefetch (falls back to primary if unset)
# DATABASE_URL_REPLICA=postgresql://USER:PASSWORD@REPLICA_HOST:5432/postgres

# ── Application ─────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ENVIRONMENT=production            # development | production
DEBUG=False
# JSON list in production; locks CORS to your domain(s)
ALLOWED_ORIGINS=["https://your-domain.example"]

# ── Auth (REQUIRED for real use) ────────────────────────────────────
# When BOTH are set, the whole app is behind an HTTP Basic gate.
# Leave unset only for local dev/tests.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me

# ── Scraping ────────────────────────────────────────────────────────
SCRAPING_USER_AGENT=Mozilla/5.0 (compatible; CPQBot/1.0)
SCRAPING_DELAY_MS=1000

# ── Catalog API integration (external Qargo catalog, JWT auth) ──────
CATALOG_API_BASE_URL=https://72.60.171.43.sslip.io
CATALOG_API_EMAIL=your-email@example.com
CATALOG_API_PASSWORD=change-me
# Weekly auto-sync cron: "day_of_week hour" (default Monday 6am)
CATALOG_SYNC_SCHEDULE=mon 6
